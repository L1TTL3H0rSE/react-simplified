{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "strict": true,
        "skipLibCheck": true,
        "types": ["node"],
        "rootDir": "src",
        "outDir": "dist",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
    },
    "include": ["src"]
}